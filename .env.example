# =============================================================================
# Cryptoreflex — variables d'environnement
# Copier ce fichier en `.env.local` (gitignored) et remplir les valeurs réelles.
# =============================================================================

# URL canonique du site (sans trailing slash). Utilisée par le sitemap, les
# canonicals, les liens absolus dans les images OG, etc.
# IMPORTANT : on inclut le `www.` parce que Vercel sert le site sur cette
# version et redirige l'apex en 308. Sans `www.`, chaque crawl bot subit
# un redirect inutile (et le canonical Google tournique entre les 2).
NEXT_PUBLIC_SITE_URL=https://www.cryptoreflex.fr

# -----------------------------------------------------------------------------
# Plausible Analytics
# -----------------------------------------------------------------------------
# Domaine déclaré dans Plausible (sans http://, sans trailing slash, en
# minuscules). DOIT correspondre EXACTEMENT à la "Site domain" affichée
# dans les paramètres du site Plausible.
#   Exemple prod   : cryptoreflex.fr
#   Exemple staging: staging.cryptoreflex.fr  (si on crée un 2e site Plausible)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=cryptoreflex.fr

# -----------------------------------------------------------------------------
# Vérification de propriété — Webmaster Tools
# -----------------------------------------------------------------------------
# Récupérés après inscription :
#   Google Search Console  : Settings > Ownership verification > HTML tag
#   Bing Webmaster Tools   : Settings > Ownership verification > Meta tag
#
# On stocke uniquement le `content="..."` (pas la balise complète).
# Cf. plan/code/analytics-setup.md pour la procédure pas-à-pas.
NEXT_PUBLIC_GOOGLE_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=

# -----------------------------------------------------------------------------
# Alertes prix crypto par email (Sprint 3)
# -----------------------------------------------------------------------------
# Stockage : Upstash KV (Redis-compatible, REST). Free tier suffisant V1
# (10 000 commandes/jour, 256 MB).
# 1. Créer une base sur https://console.upstash.com/redis (region : eu-west-1)
# 2. Onglet "REST API" → copier l'URL (sans trailing slash) et le token "Read & Write"
# 3. Si non configuré, fallback "mocked" (Map en mémoire, perdue au redéploiement)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Service d'envoi d'email transactionnel : Resend (free tier 3000 emails/mois,
# 100/jour — plus que suffisant pour les alertes crypto).
# 1. Créer un compte sur https://resend.com
# 2. Vérifier le domaine cryptoreflex.fr (DKIM + SPF) — voir la doc Resend
# 3. Générer une API key dans Settings → API Keys
# 4. Si non configuré, fallback "mocked" (les emails sont uniquement loggés).
RESEND_API_KEY=
# Adresse expéditeur. Doit être sur un domaine vérifié dans Resend.
RESEND_FROM_EMAIL=Cryptoreflex Alertes <alertes@cryptoreflex.fr>

# Secret HMAC pour signer les liens d'opt-out dans les emails d'alerte.
# Générer avec : openssl rand -base64 32
# Si absent, on retombe sur le token littéral "mocked-token" (dev uniquement).
ALERT_DELETE_SECRET=

# Token partagé pour authentifier les appels du cron Vercel.
# Le cron envoie le header `Authorization: Bearer <CRON_SECRET>`.
# Vercel injecte automatiquement ce secret dans les requêtes cron quand il est
# défini dans les variables d'environnement du projet.
# Comparaison désormais timing-safe (cf. lib/auth.ts → verifyBearer).
# Générer avec : openssl rand -hex 32
CRON_SECRET=

# Adresse expéditeur dédiée à la séquence email "Fiscalité crypto".
# Optionnel : si absent, fallback sur RESEND_FROM_EMAIL puis sur
# "Cryptoreflex Fiscalité <fiscalite@cryptoreflex.fr>".
# Doit être sur un domaine vérifié dans Resend (DKIM + SPF) sinon DMARC reject.
RESEND_FROM_FISCALITE=hello@cryptoreflex.fr

# Secret HMAC pour signer les tokens de désinscription dans les liens email.
# RGPD : ces tokens permettent au /api/newsletter/unsubscribe de valider la
# légitimité du clic sans état serveur (lookup DB / KV).
# Optionnel : si absent, fallback sur CRON_SECRET (mutualisé en MVP).
# RECOMMANDÉ en prod : provisionner une valeur dédiée pour pouvoir rotater
# CRON_SECRET indépendamment sans invalider tous les liens d'unsubscribe émis.
# Générer avec : openssl rand -base64 32
UNSUBSCRIBE_SECRET=

# Override pour autoriser les écritures FS dans les crons news / TA.
# Vercel Lambda = filesystem READ-ONLY (sauf /tmp éphémère). Les crons
# /api/cron/aggregate-news et /api/cron/generate-ta short-circuitent par défaut
# en prod (process.env.VERCEL truthy) — sinon EROFS au moindre fs.writeFile.
# Workflow recommandé : exécuter en local avec ALLOW_FS_WRITE=1, commit, push.
# Cf. plan/code/CRONS-VERCEL-LIMITATIONS.md pour les options V2 (GitHub API).
# LAISSER VIDE EN PROD. Mettre "1" UNIQUEMENT en local.
ALLOW_FS_WRITE=

# -----------------------------------------------------------------------------
# CoinMarketCal — Calendrier événements crypto (Pilier 4)
# -----------------------------------------------------------------------------
# Clé API CoinMarketCal (free tier 100 req/jour, large pour notre cron 1×/jour).
# 1. Créer un compte sur https://coinmarketcal.com/en/api/login
# 2. Récupérer la clé dans Profile → API
# Optionnel : si absent, /api/cron/refresh-events tourne en mode "seed-only"
# (utilise uniquement le seed local lib/events-seed.ts, pas de fresh fetch).
NEXT_PUBLIC_COINMARKETCAL_KEY=

# -----------------------------------------------------------------------------
# Plausible Engagement Goals (V2 roadmap)
# -----------------------------------------------------------------------------
# URL custom du script Plausible (uniquement si on bascule sur le plan payant
# avec Engagement Goals / outbound link tracking). Optionnel — vide = script
# par défaut https://plausible.io/js/script.js (free tier).
# Usage typique en V2 : "https://plausible.io/js/script.outbound-links.js"
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=

# -----------------------------------------------------------------------------
# OpenRouter — fallback LLM pour la réécriture news (Pilier 1)
# -----------------------------------------------------------------------------
# Optionnels : OpenRouter recommande de définir un Referer + Title pour
# bénéficier de la priorité de routage et apparaître dans leur dashboard public.
# Sans ces vars, le call passe quand même mais avec User-Agent par défaut.
OPENROUTER_REFERER=
OPENROUTER_TITLE=

# -----------------------------------------------------------------------------
# Microsoft Clarity — heatmaps + session recording (Sprint Conversion)
# -----------------------------------------------------------------------------
# Project ID Microsoft Clarity. 100% gratuit, illimité.
# 1. Créer un compte sur https://clarity.microsoft.com (login Microsoft)
# 2. Créer un projet "Cryptoreflex"
# 3. Copier le Project ID affiché dans Settings → Setup → Tracking code
#    (chaîne courte type "abc123xyz")
# Si vide : le script Clarity n'est pas chargé du tout (no-op).
# RGPD : chargé uniquement si l'utilisateur accepte la catégorie "analytics"
# du bandeau cookies (cf. lib/consent.ts).
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# -----------------------------------------------------------------------------
# Page admin stats (Sprint Conversion)
# -----------------------------------------------------------------------------
# Secret pour accéder à /admin/stats?token=<ADMIN_STATS_SECRET>.
# Si mismatch : 404 (security through obscurity, ne révèle pas l'existence).
# Si absent en prod : la page est inaccessible (toujours 404).
# Générer avec : openssl rand -base64 32
# Exemple (à NE PAS utiliser en prod) : BMAPLWyVlMKh2qfDyX3t1HYTbLIHDK5P
ADMIN_STATS_SECRET=

# =============================================================================
#  CRYPTOREFLEX PRO — INFRASTRUCTURE ABONNEMENT (27/04/2026)
# =============================================================================
# Variables nécessaires pour activer l'auth Supabase + le dashboard /mon-compte
# + le webhook Stripe + les emails Resend. Voir SETUP.md pour le guide complet.
# Sans ces variables, le site fonctionne en mode "Free uniquement" (degradation
# gracieuse) — /mon-compte affiche "Connexion bientôt disponible".

# -----------------------------------------------------------------------------
# Supabase (auth magic link + DB users)
# -----------------------------------------------------------------------------
# Récupérer dans Supabase Dashboard > Project Settings > API > "Legacy anon, service_role API keys"
NEXT_PUBLIC_SUPABASE_URL=https://ovolnnnmsugfhsckhivh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Stripe (webhook + Customer Portal + checkout dynamique)
# -----------------------------------------------------------------------------
# Récupérer dans Stripe Dashboard :
#  STRIPE_SECRET_KEY    : Developers > API keys > "Standard keys" > Secret key (sk_live_...)
#  STRIPE_WEBHOOK_SECRET: Developers > Webhooks > [endpoint] > "Signing secret" (whsec_...)
#  STRIPE_PRICE_*       : Products > [produit Pro Mensuel/Annuel]
#                         Accepte SOIT le Price ID (price_...) SOIT le Product ID (prod_...)
#                         Le Price ID est plus précis (1 produit peut avoir N prix).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Mensuel : prod_xxx ou price_xxx
STRIPE_PRICE_PRO_MONTHLY=
# Annuel : prod_xxx ou price_xxx
STRIPE_PRICE_PRO_ANNUAL=

